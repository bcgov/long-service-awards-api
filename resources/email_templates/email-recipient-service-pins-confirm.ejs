<%- await include('email-doctype'); %>
    <html xmlns="http://www.w3.org/1999/xhtml" lang="en">
    <%- await include('email-head', {title: title}); %>

        <body class="body"
            style="padding:0; margin:0; display:block; background:#ffffff; -webkit-text-size-adjust:none">
            <div class="container">

                <table>
                    <tr>
                        <td style="border-bottom:1px solid #e7e7e7;">
                            <%- await include('email-banner-pins'); %>
                                <p style="text-align: center"><strong>This is an automated email. No response is
                                        required.</strong></p>
                                <p>
                                    Thank you for registering for your corporate Service Pin.
                                </p>
                                <p>
                                    The corporate Service Pin program recognizes employees celebrating career
                                    milestones of five years or more, in five-year increments.
                                </p>
                                <p>
                                    Your pin(s) will be delivered to your supervisor or your <a
                                        href="https://compass.gww.gov.bc.ca/employee-recognition/ministry-recognition-contacts/">ministry
                                        recognition contact</a>
                                    in early June so they can be presented to you during <a
                                        href="https://compass.gww.gov.bc.ca/public-service-week/">Public Service
                                        Week</a>.
                                </p>
                                <p>
                                    If you have additional questions, contact
                                    your <a
                                        href="https://compass.gww.gov.bc.ca/employee-recognition/ministry-recognition-contacts/">ministry
                                        recognition contact</a>.
                                </p>
                                <%- await include('email-footer'); %>
                        </td>
                    </tr>
                </table>
            </div>
        </body>

    </html>