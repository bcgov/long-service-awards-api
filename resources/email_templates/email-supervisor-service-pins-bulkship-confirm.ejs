<%- await include('email-doctype'); %>
  <html xmlns="http://www.w3.org/1999/xhtml" lang="en">
  <%- await include('email-head', {title: title}); %>

    <body class="body" style="
      padding: 0;
      margin: 0;
      display: block;
      background: #ffffff;
      -webkit-text-size-adjust: none;
    ">

      <div class="container">

        <table>
          <tr>
            <td style="border-bottom: 1px solid #e7e7e7">
              <%- await include('email-banner-pins'); %>
                <p style="text-align: center">
                  <strong>This is an automated email. No response is required.</strong>
                </p>
                <p>
                  This email is to advise that your employee, <%= contact.first_name %>
                    <%= contact.last_name %> has registered to receive a <%= service.milestone %> year
                        <a href="https://longserviceawards.gww.gov.bc.ca/service-pins/">Corporate Service Pin</a>
                        in <%= service.cycle %>.
                </p>
                <p>
                  The corporate Service Pin program is for employees celebrating a career
                  milestone of five years of service or more, in five-year increments.
                </p>
                <p>Pins will be delivered to your <a
                    href="https://compass.gww.gov.bc.ca/employee-recognition/ministry-recognition-contacts/">ministry
                    recognition
                    contact</a> in early June. Please plan to present them during Public Service Week in a way that
                  suits
                  your employee’s recognition preferences.</p>
                <p>To ensure your employee is recognized and receives their pin, please check
                  in with your <a
                    href="https://compass.gww.gov.bc.ca/employee-recognition/ministry-recognition-contacts/">ministry
                    recognition
                    contact</a> if you have any questions, or do not
                  receive their pin.</p>
                <%- await include('email-footer'); %>
            </td>
          </tr>
        </table>
      </div>
    </body>

  </html>